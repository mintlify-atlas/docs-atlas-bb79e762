  "keyFeatures": [
    "JWT authentication with refresh token rotation and revocation",
    "RBAC with fine-grained (resource, action) permissions and wildcard support",
    "Full delivery lifecycle: orders, driver assignments, and state transitions",
    "GPS tracking with geospatial queries (nearby drivers, geofence containment)",
    "Route planning via OpenRouteService integration with automatic geofence generation",
    "Hybrid persistence: PostgreSQL for transactional data, MongoDB for geospatial/logs",
    "HTTP audit logging to MongoDB with TTL expiry",
    "File evidence uploads using MongoDB GridFS",
    "Rich KPI and analytics reporting endpoints (dashboard, SLA, driver efficiency)"
  ],
